APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_DOCS_ENABLED=true

DB_CONNECTION=mysql
# For MongoDB: set DB_CONNECTION=mongodb.
# You can use standard DB_HOST/PORT etc, or override with MONGODB_URI.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=universal_api
DB_USERNAME=root
DB_PASSWORD=

# Optional MongoDB Connection URI (overrides individual params if set)
# MONGODB_URI=mongodb://root:pass@127.0.0.1:27017/universal_api?authSource=admin

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null


# Security
JWT_SECRET=your_secure_random_generated_secret_key_at_least_32_chars
TRUSTED_PROXIES=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# Security Access Control
# Strategies: ALLOW_ALL, WHITELIST (Deny all except listed)
SECURITY_ACCESS_STRATEGY=ALLOW_ALL
SECURITY_ALLOWED_IPS=

# Limit allowed HTTP methods (comma separated, e.g. GET,POST). Empty = Allow All.
SECURITY_ALLOWED_METHODS=

# CSRF Protection
# Comma-separated list of trusted origins for CSRF checks (e.g. https://admin.example.com).
# The API's own host is automatically trusted.
CSRF_TRUSTED_ORIGINS=
# CORS
# Comma-separated list of allowed origins (e.g., https://my-app.com,https://staging.my-app.com)
CORS_ALLOWED_ORIGINS=

# Webhook Discord (Marketplace)
DISCORD_WEBHOOK_URL=

# AI Integration (Optional)
# Supported providers: openai, gemini
AI_PROVIDER=openai
AI_API_KEY=

# Social Logins
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Security
ENCRYPTION_KEY=my-secret-encryption-key-32-chars-long

# --- LEGAL & COMPLIANCE ---
# OBLIGATION LÉGALE : En passant cette variable à "true", vous confirmez avoir pris connaissance
# des risques et de vos responsabilités juridiques (ex: enregistrement PSAN / conformité MiCA)
# concernant les services d'échange d'actifs numériques (Swap, Marketplace) fournis par cette API.
# Sans cette approbation, l'API refusera de démarrer.
LEGAL_CONSENT=false


# OVHcloud S3 Config
OVH_S3_REGION=gra
OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
OVH_S3_BUCKET=my-app-images
OVH_S3_ACCESS_KEY=your_access_key
OVH_S3_SECRET_KEY=your_secret_key

# OVHcloud KMS Config
OVH_KMS_ENDPOINT=https://kms.gra.io.cloud.ovh.net
OVH_KMS_KEY_ID=your-kms-key-uuid
OVH_KMS_CERT_PATH=/path/to/your/certificate.pem
OVH_KMS_KEY_PATH=/path/to/your/private_key.pem
